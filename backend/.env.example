# ── LLM (OpenRouter) ─────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
DEFAULT_MODEL=anthropic/claude-3.5-sonnet
ROUTER_MODEL=openai/gpt-4o-mini
RAG_MODEL=openai/gpt-4o-mini
APP_URL=http://localhost:5173

# ── Embedding (OpenAI / OpenRouter / any compatible API) ──
# Priority: EMBEDDING_API_KEY > OPENAI_API_KEY > OPENROUTER_API_KEY
# Set one of them
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
#
# Example configs:
# ── Option 1: Direct OpenAI ──
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=            (leave empty for default OpenAI)
# EMBEDDING_MODEL=text-embedding-3-small
#
# ── Option 2: Via OpenRouter ──
# EMBEDDING_API_KEY=             (leave empty to use OPENROUTER_API_KEY)
# EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_MODEL=openai/text-embedding-3-small
#
# ── Option 3: Other compatible (Azure, Together, etc.) ──
# EMBEDDING_API_KEY=your-key
# EMBEDDING_BASE_URL=https://your-provider.com/v1
# EMBEDDING_MODEL=your-model-name
#
# ── Legacy ──
OPENAI_API_KEY=

# ── Data APIs ─────────────────────────────────────────────
SERPAPI_KEY=...
TAVILY_API_KEY=...

# ── Reranker (BGE-reranker-v2-m3 ONNX local) ──
# Downloaded from HuggingFace and converted to ONNX on first run
RERANKER_MODEL_DIR=./models/bge-reranker-v2-m3-onnx

# ── Infrastructure ────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Redis checkpointer for conversation persistence (requires Redis 8 with RedisJSON/RediSearch)
USE_REDIS_CHECKPOINTER=false
# CHECKPOINT_REDIS_PREFIX=lg_checkpoint
CHROMA_DIR=./chroma_db
SQLITE_PATH=./logs.db

# ── Scheduled refresh ────────────────────────────────────
KB_REFRESH_CRON_HOUR=2
KB_REFRESH_ENABLED=true

# ── Local knowledge files ─────────────────────────────────
# KB refresh will scan txt/md/docx/pdf under this directory
# Leave empty to skip local file loading
KNOWLEDGE_FILES_DIR=./knowledge_files
KNOWLEDGE_FILES_ENABLED=true

# ── Model evaluation ─────────────────────────────────────
EVAL_DATASET_PATH=./eval/eval_dataset.json
EVAL_REPORTS_DIR=./eval/reports
EVAL_JUDGE_MODEL=openai/gpt-4o

# ── Cache TTL (seconds) ──────────────────────────────────
CACHE_TTL_MARKET=3600
CACHE_TTL_NEWS=1800
CACHE_TTL_EMBEDDING=86400
CACHE_TTL_WEB_SEARCH=900

# ── Security ─────────────────────────────────────────────
ADMIN_TOKEN=your-admin-token

# ── Model override (optional; all roles use same model) ───
# OVERRIDE_ALL_MODELS=mistralai/mistral-7b-instruct

# ── Agent mode ───────────────────────────────────────────
# Coordinator mode (enforce tool use, reduce hallucination)
# true: plan tool calls before answering, require tools for data
# false: standard ReAct, model decides whether to use tools
USE_COORDINATOR=true
