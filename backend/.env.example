# ── LLM（OpenRouter）─────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
DEFAULT_MODEL=anthropic/claude-3.5-sonnet
ROUTER_MODEL=openai/gpt-4o-mini
RAG_MODEL=openai/gpt-4o-mini
APP_URL=http://localhost:5173

# ── Embedding（支持 OpenAI / OpenRouter / 任何兼容接口）──
# API Key 优先级：EMBEDDING_API_KEY > OPENAI_API_KEY > OPENROUTER_API_KEY
# 只需设置其中一个即可
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
#
# 示例配置：
# ── 方式1：直连 OpenAI ──
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=            （留空即默认 OpenAI）
# EMBEDDING_MODEL=text-embedding-3-small
#
# ── 方式2：通过 OpenRouter ──
# EMBEDDING_API_KEY=             （留空则自动用 OPENROUTER_API_KEY）
# EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_MODEL=openai/text-embedding-3-small
#
# ── 方式3：其他兼容接口（如 Azure, Together, etc.）──
# EMBEDDING_API_KEY=your-key
# EMBEDDING_BASE_URL=https://your-provider.com/v1
# EMBEDDING_MODEL=your-model-name
#
# ── 兼容旧配置 ──
OPENAI_API_KEY=

# ── 数据 API ──────────────────────────────────────────────
NEWSAPI_KEY=...
TAVILY_API_KEY=...

# ── Reranker（BGE-reranker-v2-m3 ONNX 本地推理）────────
# 首次运行时自动从 HuggingFace 下载并转换为 ONNX 格式
RERANKER_MODEL_DIR=./models/bge-reranker-v2-m3-onnx

# ── 基础设施 ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
CHROMA_DIR=./chroma_db
SQLITE_PATH=./logs.db

# ── 定时刷新 ──────────────────────────────────────────────
KB_REFRESH_CRON_HOUR=2
KB_REFRESH_ENABLED=true

# ── 本地知识文件目录 ──────────────────────────────────────
# 设置后，知识库刷新时会遍历该目录下所有 txt/md/docx/pdf 文件
# 留空则跳过本地文件加载
KNOWLEDGE_FILES_DIR=./knowledge_files
KNOWLEDGE_FILES_ENABLED=true

# ── 模型质量评估 ──────────────────────────────────────────
EVAL_DATASET_PATH=./eval/eval_dataset.json
EVAL_REPORTS_DIR=./eval/reports
EVAL_JUDGE_MODEL=openai/gpt-4o

# ── 缓存 TTL（秒）────────────────────────────────────────
CACHE_TTL_MARKET=3600
CACHE_TTL_NEWS=1800
CACHE_TTL_EMBEDDING=86400
CACHE_TTL_WEB_SEARCH=900

# ── 安全 ─────────────────────────────────────────────────
ADMIN_TOKEN=your-admin-token

# ── 模型覆盖（可选，设置后所有角色使用同一模型）──────────
# OVERRIDE_ALL_MODELS=mistralai/mistral-7b-instruct

# ── Agent 模式配置 ────────────────────────────────────────
# 是否使用协调器模式（强制工具使用，减少幻觉）
# true: 使用协调器模式，在每次回答前先规划工具调用，强制使用工具获取数据
# false: 使用标准 ReAct 模式，由模型自主决定是否使用工具
USE_COORDINATOR=true
