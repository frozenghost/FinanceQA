{
  "_comment": "Knowledge base sources example - copy to knowledge_sources.json and edit as needed",
  
  "sources": [
    {
      "_comment": "Static web pages - for finance education / docs",
      "name": "static_web_pages",
      "type": "web",
      "enabled": true,
      "fetcher": "WebPageFetcher",
      "config": {
        "urls": [
          "https://corporatefinanceinstitute.com/resources/valuation/price-earnings-ratio/",
          "https://www.investor.gov/introduction-investing/investing-basics/investment-products"
        ],
        "timeout": 30,
        "retry_count": 3
      }
    },
    
    {
      "_comment": "Wikipedia articles",
      "name": "wikipedia_articles",
      "type": "wiki",
      "enabled": true,
      "fetcher": "WikipediaFetcher",
      "config": {
        "queries": [
          "P/E ratio",
          "Price–earnings ratio",
          "EBITDA"
        ],
        "max_docs_per_query": 1
      }
    },
    
    {
      "_comment": "Yahoo Finance financial data",
      "name": "company_earnings",
      "type": "earnings",
      "enabled": true,
      "fetcher": "YahooFinanceFetcher",
      "config": {
        "tickers": ["AAPL", "TSLA", "BABA"],
        "data_fields": [
          "trailingPE",
          "priceToBook",
          "trailingEps",
          "totalRevenue",
          "profitMargins",
          "returnOnEquity",
          "industry"
        ]
      }
    },
    
    {
      "_comment": "Tavily web search - requires API key",
      "name": "web_search_results",
      "type": "tavily",
      "enabled": false,
      "fetcher": "TavilyFetcher",
      "config": {
        "queries": [
          "Alibaba latest quarterly earnings summary",
          "Tesla quarterly earnings highlights"
        ],
        "max_results_per_query": 3,
        "search_depth": "advanced"
      }
    },
    
    {
      "_comment": "Local files - txt, md, docx, pdf",
      "name": "local_documents",
      "type": "local_file",
      "enabled": true,
      "fetcher": "LocalFileFetcher",
      "config": {
        "base_directory": "${KNOWLEDGE_FILES_DIR}",
        "supported_extensions": [".txt", ".md", ".docx", ".pdf"],
        "recursive": true,
        "encoding": "utf-8"
      }
    }
  ],
  
  "chunking": {
    "_comment": "Chunking config",
    "chunk_size": 1024,
    "chunk_overlap": 128,
    "separators": ["\n\n", "\n", "。", ".", "!", "?", "；", ";", " "]
  },
  
  "vectordb": {
    "_comment": "Vector DB config",
    "collection_name": "finance_knowledge",
    "persist_directory": "${CHROMA_DIR}"
  }
}
